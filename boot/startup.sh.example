#!/data/data/com.termux/files/usr/bin/bash
# termux-shizuku 开机自启脚本模板
# 使用方法:
#   1. 复制: cp boot/startup.sh.example boot/startup.sh
#   2. 修改 SHIZUKU_START_PATH 为你的 Shizuku 启动命令
#   3. 放到 ~/.termux/boot/ 目录（需要 Termux:Boot app）
#
# Shizuku 启动命令获取方式:
#   打开 Shizuku App → "通过连接电脑启动" → 复制 adb shell 那行
#   把 "adb shell" 后面的部分填到下面

echo "=== termux-shizuku boot ==="

# 🔧 改成你的 Shizuku 启动命令（打开 Shizuku App 获取）
SHIZUKU_START_PATH="/storage/emulated/0/Android/data/moe.shizuku.privileged.api/start.sh"

(
  # 等待网络就绪（最多等 60 秒）
  for i in $(seq 1 20); do
    if adb shell whoami > /dev/null 2>&1; then
      break
    fi
    sleep 3
  done

  # 切 adbd 到 TCP 模式
  adb tcpip 5555 2>&1
  sleep 2
  adb connect 127.0.0.1:5555 2>&1

  # 通过 ADB 启动 Shizuku
  adb -s 127.0.0.1:5555 shell sh "$SHIZUKU_START_PATH" 2>&1
  sleep 5

  # 验证
  if rish -c "whoami" > /dev/null 2>&1; then
    echo "$(date) ✅ Shizuku boot OK"
  else
    echo "$(date) ❌ Shizuku boot failed — check SHIZUKU_START_PATH"
  fi
) &
